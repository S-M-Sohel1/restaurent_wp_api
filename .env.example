# Supabase — get from: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret — any strong random string (openssl rand -hex 32)
# Must match WA_SERVICE_SECRET in the admin panel
WORKER_SECRET=change_me_to_a_strong_random_secret

# Port (Render injects this automatically; override locally if needed)
PORT=8000
